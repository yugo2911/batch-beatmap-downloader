{
  "name": "batch-beatmap-downloader",
  "productName": "Batch Beatmap Downloader",
  "version": "2.0.0",
  "description": "A way to mass download osu! beatmaps with a user friendly query builder.",
  "main": ".webpack/main",
  "repository": {
    "type": "git",
    "url": "https://github.com/nzbasic/batch-beatmap-downloader.git"
  },
  "scripts": {
    "start": "electron-forge start",
    "lint": "cross-env NODE_ENV=development eslint . --cache --ext .js,.jsx,.ts,.tsx",
    "create-icons": "electron-icon-builder --input=./assets/package/source.png --output=./assets/package",
    "package:mac": "electron-forge package --platform darwin",
    "package:linux": "electron-forge package --platform linux",
    "package:win": "electron-forge package --platform win32",
    "make:mac": "electron-forge make --platform darwin",
    "make:linux": "electron-forge make --platform linux",
    "make:win": "electron-forge make --platform win32",
    "publish:mac": "electron-forge publish --platform darwin",
    "publish:linux": "electron-forge publish --platform linux",
    "publish:win": "electron-forge publish --platform win32"
  },
  "keywords": [],
  "author": {
    "name": "nzbasic",
    "email": "jamescoppard024@gmail.com"
  },
  "license": "MIT",
  "config": {
    "forge": "./.config/forge.config.js",
    "commitizen": {
      "path": "cz-conventional-changelog",
      "defaultScope": "global"
    }
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "singleQuote": false
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "cross-env NODE_ENV=development eslint --cache"
    ],
    "{*.json,.{eslintrc,prettierrc}}": [
      "prettier --ignore-path .eslintignore --parser json --write"
    ],
    "*.{css,scss}": [
      "prettier --ignore-path .eslintignore --write"
    ],
    "*.{html,md,yml}": [
      "prettier --ignore-path .eslintignore  --write"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-react": "^7.27.1",
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-webpack": "^7.8.0",
    "@electron-forge/publisher-github": "^7.8.0",
    "@electron-forge/shared-types": "^7.8.0",
    "@types/deepmerge": "^2.2.3",
    "@types/node": "^22.15.14",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/react-redux": "^7.1.34",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@zauberware/eslint-config": "^0.1.26",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "dotenv": "^16.5.0",
    "electron": "36.1.0",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9.26.0",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "husky": "^9.1.7",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@davidcmeier/string-to-color": "^2.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@reduxjs/toolkit": "^2.8.0",
    "@timfish/forge-externals-plugin": "^0.2.1",
    "@types/axios": "^0.14.4",
    "@types/electron-settings": "^4.0.2",
    "@types/humanize-duration": "^3.27.4",
    "@types/is-number": "^7.0.5",
    "@types/lodash": "^4.17.16",
    "@types/react-datepicker": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.9.0",
    "color-scales": "^3.0.2",
    "colors": "^1.4.0",
    "compress-json": "^3.1.1",
    "deep-object-diff": "^1.1.9",
    "deepmerge": "^4.3.1",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.0",
    "electron-persist-secure": "^1.3.0",
    "electron-settings": "^4.0.4",
    "electron-squirrel-startup": "^1.0.1",
    "humanize-duration": "^3.32.1",
    "ipc-node-go": "^0.2.0",
    "is-number": "^7.0.0",
    "lodash": "^4.17.21",
    "nanoid": "^5.1.5",
    "nodejs-file-downloader": "^4.13.0",
    "osu-buffer": "^2.0.2",
    "prettier": "^3.5.3",
    "rc-slider": "^11.1.8",
    "react": "^19.1.0",
    "react-datepicker": "^8.3.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.5.3",
    "react-select": "^5.10.1",
    "react-switch": "^7.1.0",
    "react-toastify": "^11.0.5",
    "realm": "^12.14.2",
    "redux-persist": "^6.0.0",
    "tailwind-scrollbar": "^4.0.2",
    "update-electron-app": "^3.1.1",
    "url2file": "^1.0.2",
    "username": "^7.0.0",
    "utf8-string-bytes": "^1.0.3",
    "uuid": "^11.1.0"
  }
}
